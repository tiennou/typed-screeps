{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2017",
        "sourceMap": false,
        "declaration": true,
        "strict": true,
        "noEmit": true,
        "newLine": "LF",
        "removeComments": false,
        "allowJs": true
    },
    "include": [
        "./src/**/*.ts",
        "eslint.config.js",
        "build/concat.js"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
